#!/bin/sh

. /lib/functions.sh
. /lib/functions/network.sh
. /usr/share/libubox/jshn.sh
. /lib/mwan3/common.sh
. /lib/mwan3/mwan3.sh

MWAN3TRACK_STATUS_DIR="/var/run/mwan3track"

get_uptime() {
	awk '{print int($1)}' /proc/uptime
}

_cat_file() {
	cat "$1" 2>/dev/null || echo "0"
}

report_connected_v4() {
	local address
	$NFT list set $MWAN3_NFT_TABLE mwan3_connected_v4 2>/dev/null | \
		awk '/elements/ { p=1; next }
		     p && /}/ { p=0; next }
		     p { gsub(/[{},]/, ""); for(i=1;i<=NF;i++) if($i!="") print $i }' | \
		while read address; do
			json_add_string "" "${address}"
		done
}

report_connected_v6() {
	local address
	$NFT list set $MWAN3_NFT_TABLE mwan3_connected_v6 2>/dev/null | \
		awk '/elements/ { p=1; next }
		     p && /}/ { p=0; next }
		     p { gsub(/[{},]/, ""); for(i=1;i<=NF;i++) if($i!="") print $i }' | \
		while read address; do
			json_add_string "" "${address}"
		done
}

report_policies_v4() {
	config_foreach _rpcd_report_policy policy
}

report_policies_v6() {
	config_foreach _rpcd_report_policy policy
}

_rpcd_member_weight() {
	local member="$1"
	local iface weight metric status
	config_get iface "$member" interface
	config_get weight "$member" weight 1
	config_get metric "$member" metric 1
	[ -z "$iface" ] && return
	mwan3_get_iface_hotplug_state status "$iface"
	[ "$status" = "online" ] || return
	echo "$iface:$weight:$metric" >> "/tmp/mwan3_rpcd_members_$$.tmp"
}

_rpcd_report_policy() {
	local policy="$1"
	local members_file="/tmp/mwan3_rpcd_members_$$.tmp"
	rm -f "$members_file"

	config_list_foreach "$policy" use_member _rpcd_member_weight

	[ -f "$members_file" ] || return

	# Find lowest metric
	local lowest=256 m metric
	while IFS= read -r m; do
		metric="${m##*:}"
		[ "$metric" -lt "$lowest" ] && lowest=$metric
	done < "$members_file"

	# Total weight at lowest metric
	local total_weight=0 weight
	while IFS= read -r m; do
		metric="${m##*:}"; weight=$(echo "$m" | cut -d: -f2)
		[ "$metric" -eq "$lowest" ] && total_weight=$((total_weight + weight))
	done < "$members_file"

	[ "$total_weight" -eq 0 ] && { rm -f "$members_file"; return; }

	json_add_array "$policy"
	local iface percent
	while IFS= read -r m; do
		iface=$(echo "$m" | cut -d: -f1)
		weight=$(echo "$m" | cut -d: -f2)
		metric="${m##*:}"
		[ "$metric" -eq "$lowest" ] || continue
		percent=$(( weight * 100 / total_weight ))
		json_add_object
		json_add_string interface "$iface"
		json_add_int percent "$percent"
		json_close_object
	done < "$members_file"
	json_close_array

	rm -f "$members_file"
}

get_mwan3_status() {
	local iface="${1}"
	local iface_select="${2}"
	local running="0"
	local age=0
	local online=0
	local offline=0
	local up="0"
	local enabled pid device time_p time_n time_u time_d status

	network_get_device device $1

	if [ "${iface}" = "${iface_select}" ] || [ "${iface_select}" = "" ]; then
		pid="$(pgrep -f "mwan3track $iface $device")"
		if [ "${pid}" != "" ]; then
			running="1"
		fi

		time_p="$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/TIME")"
		[ -z "${time_p}" ] || [ "${time_p}" = "0" ] || {
			time_n="$(get_uptime)"
			age=$((time_n-time_p))
		}

		time_u="$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/ONLINE")"
		[ -z "${time_u}" ] || [ "${time_u}" = "0" ] || {
			time_n="$(get_uptime)"
			online=$((time_n-time_u))
		}

		time_d="$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/OFFLINE")"
		[ -z "${time_d}" ] || [ "${time_d}" = "0" ] || {
			time_n="$(get_uptime)"
			offline=$((time_n-time_d))
		}

		local uptime="0"

		config_get enabled "$iface" enabled 0
		network_get_uptime uptime "$iface"
		network_is_up "$iface" && up="1"

		if [ -f "$MWAN3TRACK_STATUS_DIR/${iface}/STATUS" ]; then
			status="$(cat "$MWAN3TRACK_STATUS_DIR/${iface}/STATUS")"
		else
			status="unknown"
		fi

		json_add_object "${iface}"
		json_add_int age "$age"
		json_add_int online "${online}"
		json_add_int offline "${offline}"
		json_add_int uptime "${uptime}"
		json_add_int "score" "$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/SCORE")"
		json_add_int "lost" "$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/LOST")"
		json_add_int "turn" "$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/TURN")"
		json_add_string "status" "${status}"
		json_add_boolean "enabled" "${enabled}"
		json_add_boolean "running" "${running}"
		json_add_boolean "up" "${up}"
		json_add_array "track_ip"
		for file in $MWAN3TRACK_STATUS_DIR/${iface}/TRACK_*; do
			[ -f "$file" ] || continue
			track="${file##*/TRACK_}"
			json_add_object
			json_add_string ip "${track}"
			json_add_string status "$(cat "${file}" 2>/dev/null)"
			json_add_int latency "$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/LATENCY_${track}")"
			json_add_int packetloss "$(_cat_file "$MWAN3TRACK_STATUS_DIR/${iface}/LOSS_${track}")"
			json_close_object
		done
		json_close_array
		json_close_object
	fi
}

main () {

	case "$1" in
		list)
			json_init
			json_add_object "status"
			json_add_string "section" "x"
			json_add_string "interface" "x"
			json_add_string "policies" "x"
			json_close_object
			json_dump
			;;
		call)
			case "$2" in
			status)
				local section iface
				read input;
				json_load "$input"
				json_get_var section section
				json_get_var iface interface

				config_load mwan3
				json_init
				case "$section" in
					interfaces)
						json_add_object interfaces
						config_foreach get_mwan3_status interface "${iface}"
						json_close_object
						;;
					connected)
						json_add_object connected
						json_add_array ipv4
						report_connected_v4
						json_close_array
						json_add_array ipv6
						report_connected_v6
						json_close_array
						json_close_object
						;;
					policies)
						json_add_object policies
						json_add_object ipv4
						report_policies_v4
						json_close_object
						json_add_object ipv6
						report_policies_v6
						json_close_object
						json_close_object
						;;
					*)
						# interfaces
						json_add_object interfaces
						config_foreach get_mwan3_status interface
						json_close_object
						# connected
						json_add_object connected
						json_add_array ipv4
						report_connected_v4
						json_close_array
						json_add_array ipv6
						report_connected_v6
						json_close_array
						json_close_object
						# policies
						json_add_object policies
						json_add_object ipv4
						report_policies_v4
						json_close_object
						json_add_object ipv6
						report_policies_v6
						json_close_object
						json_close_object
						;;
				esac
				json_dump
				;;
			esac
			;;
	esac
}

main "$@"
